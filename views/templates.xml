<odoo>
    <data>
        <template id="listing">
          <ul>
            <li t-foreach="objects" t-as="object">
              <a t-attf-href="#{ root }/objects/#{ object.id }">
                <t t-esc="object.display_name"/>
              </a>
            </li>
          </ul>
        </template>
        <template id="object">
          <h1><t t-esc="object.display_name"/></h1>
          <dl>
            <dt>Name</dt>
            <dd><t t-esc="object.name"/></dd>
            <dt>Value</dt>
            <dd><t t-esc="object.value"/></dd>
          </dl>
        </template>
    </data>
</odoo>
