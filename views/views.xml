<odoo>
  <data>
    <!-- explicit list view definition -->
    <record id="freee_conect.list" model="ir.ui.view">
      <field name="name">freee_conect list</field>
      <field name="model">freee_conect.freee_conect</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
        </tree>
      </field>
    </record>

    <!-- actions opening views on models -->
    <record id="freee_conect.action_window" model="ir.actions.act_window">
      <field name="name">freee_conect window</field>
      <field name="res_model">freee_conect.freee_conect</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- server action to the one above -->
    <record id="freee_conect.action_server" model="ir.actions.server">
      <field name="name">freee_conect server</field>
      <field name="model_id" ref="model_freee_conect_freee_conect"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "tree,form",
          "res_model": model._name,
        }
      </field>
    </record>

    <!-- Top menu item -->
    <menuitem name="freee_conect" id="freee_conect.menu_root"/>

    <!-- menu categories -->
    <menuitem name="Menu 1" id="freee_conect.menu_1" parent="freee_conect.menu_root"/>
    <menuitem name="Menu 2" id="freee_conect.menu_2" parent="freee_conect.menu_root"/>

    <!-- actions -->
    <menuitem name="List" id="freee_conect.menu_1_list" parent="freee_conect.menu_1"
              action="freee_conect.action_window"/>
    <menuitem name="Server to list" id="freee_conect" parent="freee_conect.menu_2"
              action="freee_conect.action_server"/>
  </data>
</odoo>
